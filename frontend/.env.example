# Vite client-facing API base.
# Keep this at /api for browser-based local dev.
VITE_API_BASE_URL=/api

# Vite dev-server proxy target.
# The current backend serves root-mounted routes, so the proxy rewrites
# /api/* -> /* as the supported local-demo setup.
MTG_FRONTEND_PROXY_TARGET=http://127.0.0.1:8000
